# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Card Kingdom dump endpoint
CK_PRICELIST_URL=https://api.cardkingdom.com/api/v2/pricelist

# GitHub workflow_dispatch (used by /api/refresh button)
# Fine-grained PAT with "Actions: read & write" on this repo only.
GITHUB_OWNER=cardsandhobbies
GITHUB_REPO=champsuite-ckd
GITHUB_DISPATCH_TOKEN=ghp_...
GITHUB_WORKFLOW_FILE=sync.yml

# Server-side rate-limit window for /api/refresh (seconds)
REFRESH_COOLDOWN_SECONDS=600
